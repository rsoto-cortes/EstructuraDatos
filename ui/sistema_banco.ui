  <property name="styleSheet">
   <string notr="true">/* Estilo general del diálogo */
QDialog {
    background-color: #f5f5f5;   /* Fondo claro */
    border: 1px solid #dcdcdc;   /* Borde sutil */
    border-radius: 8px;          /* Esquinas suaves */
    color: #333333;              /* Texto neutro */
}

/* Etiquetas */
QLabel {
    color: #444444;              /* Gris oscuro para contraste */
    padding: 4px;
}

/* Campos de texto */
QLineEdit {
    background-color: #ffffff;   /* Fondo blanco */
    border: 1px solid #cccccc;   /* Borde suave */
    border-radius: 4px;
    padding: 6px;
    selection-background-color: #87cefa; /* Azul claro al seleccionar */
    selection-color: #000000;
}

QLineEdit:focus {
    border: 1px solid #1a73e8;   /* Azul corporativo al enfocar */
    background-color: #fafafa;
}

/* Botones */
QPushButton {
    background-color: #1a73e8;   /* Azul profesional */
    color: #ffffff;
    border: none;
    border-radius: 4px;
    padding: 8px 14px;
    font-weight: bold;
}

QPushButton:hover {
    background-color: #1669c1;   /* Azul más intenso al pasar el cursor */
}

QPushButton:pressed {
    background-color: #0d47a1;   /* Azul profundo al presionar */
}

QPushButton:disabled {
    background-color: #e0e0e0;   /* Gris claro para deshabilitado */
    color: #888888;
}
</string>
